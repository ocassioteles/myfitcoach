# Academia API - Exemplo de variáveis de ambiente
# Copie para .env e ajuste os valores

# Banco de dados (ajuste para PostgreSQL se desejar)
DATABASE_URL="file:./dev.db"

# JWT RS256 (use chaves seguras em produção)
# Você pode gerar um par de chaves com:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Em ambientes com KMS, armazene as chaves/ARNs no KMS e injete por env/secret manager.

JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREMEOVA-COLE_AQUI_SUA_CHAVE_PRIVADA_EM_PEM\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREMEOVA-COLE_AQUI_SUA_CHAVE_PUBLICA_EM_PEM\n-----END PUBLIC KEY-----\n"

# Expiração de tokens
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="30d"

# Porta da API
PORT=3000
