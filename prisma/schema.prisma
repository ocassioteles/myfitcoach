generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Enums para maior consistência
enum Difficulty {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

// Modelo de Usuário
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  bio       String?  // Biografia do usuário
  avatar    String?  // URL do avatar
  isPublic  Boolean  @default(true) // Perfil público ou privado
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Autenticação
  passwordHash String? // Hash de senha Argon2id (opcional inicialmente para migração)
  
  // Relacionamentos básicos
  workoutTemplates WorkoutTemplate[]
  workoutSessions  WorkoutSession[]
  payments         Payment[]
  
  // Relacionamentos sociais
  followers         Follow[] @relation("UserFollowers")
  following         Follow[] @relation("UserFollowing")
  workoutComments   WorkoutComment[]
  comparisonsAsUser1 ExerciseComparison[] @relation("ComparisonUser1")
  comparisonsAsUser2 ExerciseComparison[] @relation("ComparisonUser2")
  // Tokens de refresh
  refreshTokens     RefreshToken[]
  
  @@map("users")
}

// Template de Treino (modelo/receita do treino)
model WorkoutTemplate {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  difficulty  Difficulty
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  // Relacionamentos
  userId              Int
  user                User                     @relation(fields: [userId], references: [id])
  exerciseTemplates   ExerciseTemplate[]
  workoutSessions     WorkoutSession[]
  
  @@map("workout_templates")
}

// Template de Exercício (modelo do exercício)
model ExerciseTemplate {
  id               Int      @id @default(autoincrement())
  name             String
  targetSets       Int
  targetReps       String   // "10-12" ou "30 segundos"
  targetWeight     Float?
  restTime         Int?     // segundos de descanso
  notes            String?
  order            Int      // ordem no treino
  createdAt        DateTime @default(now())
  
  // Relacionamentos
  workoutTemplateId Int
  workoutTemplate   WorkoutTemplate @relation(fields: [workoutTemplateId], references: [id])
  exerciseLogs      ExerciseLog[]
  
  @@map("exercise_templates")
}

// Sessão de Treino (cada vez que o usuário treina)
model WorkoutSession {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  duration    Int?     // duração real em minutos
  notes       String?
  completed   Boolean  @default(false)
  isPublic    Boolean  @default(true) // Treino público para comunidade
  
  // Relacionamentos
  userId            Int
  user              User            @relation(fields: [userId], references: [id])
  workoutTemplateId Int
  workoutTemplate   WorkoutTemplate @relation(fields: [workoutTemplateId], references: [id])
  exerciseLogs      ExerciseLog[]
  comments          WorkoutComment[] // Comentários da comunidade
  
  @@map("workout_sessions")
}

// Log de Exercício (cada série executada)
model ExerciseLog {
  id            Int      @id @default(autoincrement())
  setNumber     Int      // número da série (1, 2, 3...)
  actualReps    Int      // repetições realmente feitas
  actualWeight  Float?   // peso realmente usado
  restTime      Int?     // descanso real em segundos
  completed     Boolean  @default(true)
  notes         String?
  timestamp     DateTime @default(now())
  
  // Relacionamentos
  workoutSessionId    Int
  workoutSession      WorkoutSession   @relation(fields: [workoutSessionId], references: [id])
  exerciseTemplateId  Int
  exerciseTemplate    ExerciseTemplate @relation(fields: [exerciseTemplateId], references: [id])
  
  @@map("exercise_logs")
}

// Modelo de Pagamento (mantido igual)
model Payment {
  id        Int           @id @default(autoincrement())
  amount    Float
  dueDate   DateTime
  paidDate  DateTime?
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  
  // Relacionamentos
  userId Int
  user   User @relation(fields: [userId], references: [id])
  
  @@map("payments")
}

// Modelo para seguir outros usuários
model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int      // Quem está seguindo
  followingId Int      // Quem está sendo seguido
  createdAt   DateTime @default(now())
  
  // Relacionamentos
  follower  User @relation("UserFollowers", fields: [followerId], references: [id])
  following User @relation("UserFollowing", fields: [followingId], references: [id])
  
  // Evitar seguir o mesmo usuário duas vezes
  @@unique([followerId, followingId])
  @@map("follows")
}

// Modelo para comentários em treinos
model WorkoutComment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  
  // Relacionamentos
  userId            Int
  user              User            @relation(fields: [userId], references: [id])
  workoutSessionId  Int
  workoutSession    WorkoutSession  @relation(fields: [workoutSessionId], references: [id])
  
  @@map("workout_comments")
}

// Modelo para comparativo de exercícios entre usuários
model ExerciseComparison {
  id          Int      @id @default(autoincrement())
  exerciseName String  // Nome do exercício para comparar
  createdAt   DateTime @default(now())
  
  // Relacionamentos
  user1Id Int
  user2Id Int
  user1   User @relation("ComparisonUser1", fields: [user1Id], references: [id])
  user2   User @relation("ComparisonUser2", fields: [user2Id], references: [id])
  
  @@map("exercise_comparisons")
}

// Modelo de Refresh Token com rotação e expiração
model RefreshToken {
  id              Int       @id @default(autoincrement())
  tokenHash       String    // Hash do token de refresh (não armazenar em texto puro)
  jti             String    @unique // ID único do token
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  replacedByToken String?   // jti do novo token gerado na rotação

  // Relacionamento
  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}